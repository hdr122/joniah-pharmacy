# Database Configuration (PostgreSQL on Railway)
DATABASE_URL=postgresql://user:password@host:5432/joniah_pharmacy

# JWT Secret for session tokens (generate a strong random string)
JWT_SECRET=your-secret-key-here

# OAuth Configuration
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_APP_ID=your-app-id-here
OWNER_OPEN_ID=your-owner-id-here

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Firebase Service Account (get from Firebase Console > Project Settings > Service Accounts)
# This should be a JSON string with all service account fields
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"..."}'

# Server Configuration
PORT=3000
NODE_ENV=production
